COMPOSE_PROJECT_NAME=ab-next

# Published images
AB_IMAGE_TAG=v0.1.9
AB_BACK_IMAGE=ghcr.io/agent-bridges/ab-back:${AB_IMAGE_TAG}
AB_FRONT_IMAGE=ghcr.io/agent-bridges/ab-front:${AB_IMAGE_TAG}

# Shared workspace and state
AB_WORKSPACE_PATH=__REPO_ROOT__
AB_BACK_STATE_DIR=./state/back
AB_PTY_STATE_DIR=./state/pty
AB_PTY_CLAUDE_DIR=./state/pty/dot-claude
AB_PTY_CLAUDE_JSON_PATH=./state/pty/claude.json

# Child repo paths for dev/test workflows
AB_BACK_PATH=./ab-back
AB_FRONT_PATH=./ab-front
AB_PTY_PATH=./ab-pty

# Published stack ports
AB_BACKEND_PORT=8520
AB_FRONT_PORT=5281

# Auth and browser access
AB_JWT_SECRET_PATH=/absolute/path/to/change-me.jwt-secret
AB_DEFAULT_USERNAME=admin
AB_DEFAULT_PASSWORD=admin
AB_PTY_ALLOWED_ORIGINS=http://127.0.0.1:5281

# Optional browser HTTPS / mTLS edge
AB_TLS_FRONTEND_PORT=5443
AB_TLS_CERT_MOUNT_SRC=
AB_TLS_KEY_MOUNT_SRC=
AB_TLS_BROWSER_CA_MOUNT_SRC=

# Optional remote daemon HTTPS / mTLS mounts
AB_BACK_PTY_TLS_CA_MOUNT_SRC=
AB_BACK_PTY_TLS_CLIENT_CERT_MOUNT_SRC=
AB_BACK_PTY_TLS_CLIENT_KEY_MOUNT_SRC=

# Optional private release access while repos remain closed
AB_PTY_DOWNLOAD_TOKEN=

# Default demo agent for prod/dev stack
AB_DEMO_AGENT_NAME=docker-demo-agent
AB_DEMO_AGENT_IP=agent-demo:8421
AB_DEMO_AGENT_STATE_DIR=./state/demo/agent/data
AB_DEMO_AGENT_JWT_SECRET_PATH=./state/demo/agent/.jwt-secret

# Isolated test stack
AB_TEST_COMPOSE_PROJECT_NAME=ab-test
AB_TEST_BACKEND_PORT=8620
AB_TEST_FRONT_PORT=5381
AB_TEST_AGENT1_PORT=19421
AB_TEST_AGENT2_PORT=19422
AB_TEST_ADMIN_USERNAME=admin
AB_TEST_ADMIN_PASSWORD=admin
AB_TEST_AGENT1_NAME=docker-test-agent-1
AB_TEST_AGENT1_IP=agent-test-1:8421
AB_TEST_AGENT1_STATE_DIR=./state/test/agent1/data
AB_TEST_AGENT1_JWT_SECRET_PATH=./state/test/agent1/.jwt-secret
AB_TEST_AGENT2_NAME=docker-test-agent-2
AB_TEST_AGENT2_IP=agent-test-2:8421
AB_TEST_AGENT2_STATE_DIR=./state/test/agent2/data
AB_TEST_AGENT2_JWT_SECRET_PATH=./state/test/agent2/.jwt-secret
