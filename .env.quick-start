# Quick-start credentials
AB_DEFAULT_USERNAME=admin
AB_DEFAULT_PASSWORD=admin

# Published images
AB_QUICK_START_BACK_IMAGE=ghcr.io/agent-bridges/ab-back:v0.1.8
AB_QUICK_START_FRONT_IMAGE=ghcr.io/agent-bridges/ab-front:v0.1.8
AB_QUICK_START_PTY_RELEASE_TAG=v0.1.8

# Exposed ports
AB_QUICK_START_BACKEND_PORT=8520
AB_QUICK_START_FRONT_PORT=5281

# Browser access
AB_QUICK_START_PTY_ALLOWED_ORIGINS=http://127.0.0.1:5281,http://localhost:5281
AB_PTY_DOWNLOAD_TOKEN=

# Seeded demo agents
AB_QUICK_START_DEMO_AGENT_NAME=docker-demo-agent
AB_QUICK_START_DEMO_AGENT_IP=agent-demo:8421
AB_QUICK_START_DEMO_AGENT_2_NAME=docker-demo-agent-2
AB_QUICK_START_DEMO_AGENT_2_IP=agent-demo-2:8421
